<Window x:Class="MyMediaPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="My Media Player" Height="600" Width="1000"
        MinHeight="450" MinWidth="700"
        Background="{DynamicResource BackgroundBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="My Media Player" FontSize="18" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource IconButtonStyle}" Click="ToggleTheme_Click" 
                            Foreground="White" ToolTip="Toggle Theme">
                        <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" Click="ToggleLogPanel_Click"
                            Foreground="White" ToolTip="Toggle Logs">
                        <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Collections" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>

                    <ListBox x:Name="CollectionsListBox" Grid.Row="1"
                             Style="{StaticResource ListBoxStyle}"
                             ItemsSource="{Binding Collections}"
                             SelectedItem="{Binding SelectedCollection}"
                             DisplayMemberPath="Name"
                             SelectionChanged="CollectionsListBox_SelectionChanged"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Style="{StaticResource ButtonStyle}" Content="Add"
                                Command="{Binding AddCollectionCommand}" Margin="0,0,4,0"/>
                        <Button Style="{StaticResource ButtonStyle}" Content="Delete"
                                Command="{Binding DeleteCollectionCommand}" Margin="0,0,4,0"/>
                        <Button Style="{StaticResource ButtonStyle}" Content="Rename"
                                Command="{Binding RenameCollectionCommand}" Click="RenameCollection_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Playlist" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"/>

                    <Border Grid.Row="1" Background="{DynamicResource PrimaryBrush}" CornerRadius="4" Padding="12,8" Margin="0,8,0,8"
                            Visibility="{Binding CurrentMedia, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Now Playing" FontSize="11" Foreground="#CCFFFFFF"/>
                            <TextBlock Text="{Binding CurrentMedia.Title}" FontSize="14" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CurrentMedia.FilePath}" FontSize="11" Foreground="#99FFFFFF" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="PlaylistDataGrid" Grid.Row="2"
                              ItemsSource="{Binding Playlist}"
                              SelectedItem="{Binding SelectedMediaItem, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              Background="{DynamicResource SecondaryBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              CanUserReorderColumns="True"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              MouseDoubleClick="PlaylistDataGrid_MouseDoubleClick"
                              AllowDrop="True"
                              Drop="PlaylistDataGrid_Drop"
                              DragOver="PlaylistDataGrid_DragOver">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Duration" Binding="{Binding DurationText}" Width="80"/>
                            <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Style="{StaticResource ButtonStyle}" Content="Add Files"
                                Command="{Binding AddFilesCommand}" Margin="0,0,4,0"/>
                        <Button Style="{StaticResource ButtonStyle}" Content="Remove"
                                Command="{Binding RemoveItemCommand}" Margin="0,0,4,0"/>
                        <Button Style="{StaticResource ButtonStyle}" Content="Clear"
                                Command="{Binding ClearPlaylistCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" x:Name="LogPanel" Style="{StaticResource PanelStyle}" Width="300"
                    Visibility="{Binding IsLogPanelVisible, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <TextBlock Text="Logs" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <Button Style="{StaticResource MenuButtonStyle}" Content="Clear"
                                Command="{Binding ClearLogsCommand}"
                                HorizontalAlignment="Right"/>
                    </Grid>

                    <ListBox x:Name="LogListBox" Grid.Row="1"
                             Style="{StaticResource ListBoxStyle}"
                             ItemsSource="{Binding LogEntries}"
                             Margin="0,8,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="11">
                                        <Run Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"/>
                                        <Run Text=" - "/>
                                        <Run Text="{Binding Level}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextBrush}" FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource SecondaryBrush}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <MediaElement x:Name="MediaPlayer" 
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"
                              MediaOpened="MediaPlayer_MediaOpened"
                              MediaEnded="MediaPlayer_MediaEnded"
                              MediaFailed="MediaPlayer_MediaFailed"
                              Stretch="None"
                              Visibility="Collapsed"/>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Slider x:Name="ProgressSlider" 
                            Minimum="0" Maximum="1" 
                            Value="0"
                            PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                            PreviewMouseUp="ProgressSlider_PreviewMouseUp"
                            ValueChanged="ProgressSlider_ValueChanged"
                            VerticalAlignment="Center"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                        <TextBlock x:Name="CurrentTimeText" Text="00:00"
                                   Foreground="{DynamicResource TextBrush}" 
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="/" Foreground="{DynamicResource TextBrush}" 
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="TotalTimeText" Text="00:00"
                                   Foreground="{DynamicResource TextBrush}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource IconButtonStyle}" Command="{Binding PreviousCommand}"
                                ToolTip="Previous">
                            <TextBlock Text="&#xE892;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" x:Name="PlayButton"
                                Click="PlayPause_Click" ToolTip="Play/Pause">
                            <TextBlock x:Name="PlayPauseIcon" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="24"/>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" Command="{Binding StopCommand}"
                                ToolTip="Stop">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" Command="{Binding NextCommand}"
                                ToolTip="Next">
                            <TextBlock Text="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <Slider x:Name="VolumeSlider" 
                                Width="100" Minimum="0" Maximum="1" Value="0.5"
                                ValueChanged="VolumeSlider_ValueChanged"
                                VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
